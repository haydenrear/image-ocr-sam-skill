{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/vision-toolbelt.analysis.schema.json",
  "title": "Vision Toolbelt Analysis",
  "type": "object",
  "required": [
    "schema_version",
    "image",
    "ocr",
    "regions",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "vision-toolbelt.analysis.v1"
    },
    "image": {
      "type": "object",
      "required": [
        "path",
        "width",
        "height",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string"
        },
        "mime": {
          "type": "string"
        }
      }
    },
    "caption": {
      "type": "object"
    },
    "ocr": {
      "type": "array"
    },
    "regions": {
      "type": "array"
    },
    "artifacts": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
